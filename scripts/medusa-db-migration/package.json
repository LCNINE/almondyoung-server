{
  "name": "medusa-db-migration",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "description": "Direct Medusa DB migration scripts (read-first).",
  "scripts": {
    "categories": "../with-ipv4.sh ts-node src/index.ts categories",
    "db:pull:medusa": "../with-ipv4.sh drizzle-kit pull --config drizzle.medusa.config.ts",
    "db:pull:pim": "../with-ipv4.sh drizzle-kit pull --config drizzle.pim.config.ts",
    "db:generate:medusa": "../with-ipv4.sh drizzle-kit generate --config drizzle.medusa.config.ts",
    "db:generate:pim": "../with-ipv4.sh drizzle-kit generate --config drizzle.pim.config.ts"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "dotenv": "^16.4.1",
    "drizzle-orm": "1.0.0-beta.12-a5629fb",
    "pg": "^8.17.2",
    "postgres": "^3.4.3",
    "ulid": "^2.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/pg": "^8.16.0",
    "drizzle-kit": "1.0.0-beta.12-a5629fb",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
