# ===========================================
# Almondyoung Server Environment Variables
# ===========================================

# === Application Settings ===
NODE_ENV=development
PORT=3000

#CORS 오리진 프론트 주소
CORS_ORIGIN_DOMAIN=http://localhost:8000

# === Neon Database (PostgreSQL) ===
# Get from: https://console.neon.tech/
# Format: postgresql://[user]:[password]@[host]/[dbname]?sslmode=require
DATABASE_URL=postgresql://username:password@ep-xxxxx.us-east-1.aws.neon.tech/almondyoung?sslmode=require

# === Redis (Optional - for caching/sessions) ===
# Leave empty to use local Redis (docker-compose --profile dev)
# Or use cloud Redis (e.g., Redis Cloud, Upstash)
REDIS_URL=redis://localhost:6379

# === Confluent Kafka (Managed) ===
# Get from: https://confluent.cloud/
KAFKA_BROKERS=pkc-xxxxx.us-east-1.aws.confluent.cloud:9092
KAFKA_API_KEY=your-kafka-api-key
KAFKA_API_SECRET=your-kafka-api-secret
KAFKA_CLIENT_ID_PREFIX=your-kafka-id
KAFKA_GROUP_ID=your-kafka-group-id

# === JWT & Security ===
JWT_SECRET=your-super-secret-jwt-key-here
JWT_REFRESH_SECRET=your-super-secret-refresh-key-here

# === Social Security ===
KAKAO_CLIENT_ID=your-kakao-client-id
KAKAO_CLIENT_SECRET=your-kakao-client-secret-key
KAKAO_CALLBACK_URL=your-kakao-callback-url

# === AWS S3 (File Storage) ===
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=almondyoung-files

# === Payment & External APIs ===
# HMS BNPL
HMS_API_KEY=your-hms-api-key
HMS_API_SECRET=your-hms-secret

# Twilio (SMS)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase-client-email

# === Naver Commerce API ===
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret

# === Coupang API ===
COUPANG_ACCESS_KEY=your-coupang-access-key
COUPANG_SECRET_KEY=your-coupang-secret-key

# === 개발/테스트 설정 ===
LOG_LEVEL=info
DEBUG=false

# === Service URLs (for inter-service communication) ===
WMS_SERVICE_URL=http://localhost:3010
PIM_SERVICE_URL=http://localhost:3020
USER_SERVICE_URL=http://localhost:3030
WALLET_SERVICE_URL=http://localhost:3040
MEMBERSHIP_SERVICE_URL=http://localhost:3050
NOTIFICATION_SERVICE_URL=http://localhost:3060
CHANNEL_ADAPTER_SERVICE_URL=http://localhost:3070