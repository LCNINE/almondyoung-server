{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/almondyoung-server/src",
  "defaultLibraryPrefix": "@app",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "webpackConfigPath": "webpack.config.js",
    "tsConfigPath": "apps/almondyoung-server/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/almondyoung-server",
  "projects": {
    "almondyoung-server": {
      "type": "application",
      "root": "apps/almondyoung-server",
      "entryFile": "main",
      "sourceRoot": "apps/almondyoung-server/src",
      "compilerOptions": {
        "tsConfigPath": "apps/almondyoung-server/tsconfig.app.json"
      }
    },
    "analytics": {
      "type": "application",
      "root": "apps/analytics",
      "entryFile": "main",
      "sourceRoot": "apps/analytics/src",
      "compilerOptions": {
        "tsConfigPath": "apps/analytics/tsconfig.app.json"
      }
    },
    "channel-adapter": {
      "type": "application",
      "root": "apps/channel-adapter",
      "entryFile": "main",
      "sourceRoot": "apps/channel-adapter/src",
      "compilerOptions": {
        "tsConfigPath": "apps/channel-adapter/tsconfig.app.json"
      }
    },
    "db": {
      "type": "library",
      "root": "libs/db",
      "entryFile": "index",
      "sourceRoot": "libs/db/src",
      "compilerOptions": {
        "tsConfigPath": "libs/db/tsconfig.lib.json"
      }
    },
    "events-test": {
      "type": "application",
      "root": "apps/events-test",
      "entryFile": "main",
      "sourceRoot": "apps/events-test/src",
      "compilerOptions": {
        "tsConfigPath": "apps/events-test/tsconfig.json"
      }
    },
    "file-service": {
      "type": "application",
      "root": "apps/file-service",
      "entryFile": "main",
      "sourceRoot": "apps/file-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/file-service/tsconfig.app.json"
      }
    },
    "membership": {
      "type": "application",
      "root": "apps/membership",
      "entryFile": "main",
      "sourceRoot": "apps/membership/src",
      "compilerOptions": {
        "tsConfigPath": "apps/membership/tsconfig.app.json"
      }
    },
    "notification": {
      "type": "application",
      "root": "apps/notification",
      "entryFile": "main",
      "sourceRoot": "apps/notification/src",
      "compilerOptions": {
        "tsConfigPath": "apps/notification/tsconfig.app.json"
      }
    },
    "orchestrator": {
      "type": "application",
      "root": "apps/orchestrator",
      "entryFile": "main",
      "sourceRoot": "apps/orchestrator/src",
      "compilerOptions": {
        "tsConfigPath": "apps/orchestrator/tsconfig.app.json"
      }
    },
    "outbox-demo": {
      "type": "application",
      "root": "apps/outbox-demo",
      "entryFile": "main",
      "sourceRoot": "apps/outbox-demo/src",
      "compilerOptions": {
        "tsConfigPath": "apps/outbox-demo/tsconfig.app.json"
      }
    },
    "pim": {
      "type": "application",
      "root": "apps/pim",
      "entryFile": "main",
      "sourceRoot": "apps/pim/src",
      "compilerOptions": {
        "tsConfigPath": "apps/pim/tsconfig.app.json"
      }
    },
    "search": {
      "type": "application",
      "root": "apps/search",
      "entryFile": "main",
      "sourceRoot": "apps/search/src",
      "compilerOptions": {
        "tsConfigPath": "apps/search/tsconfig.app.json"
      }
    },
    "shared": {
      "type": "library",
      "root": "libs/shared",
      "entryFile": "index",
      "sourceRoot": "libs/shared/src",
      "compilerOptions": {
        "tsConfigPath": "libs/shared/tsconfig.lib.json"
      }
    },
    "test-auth-scope": {
      "type": "application",
      "root": "apps/test-auth-scope",
      "entryFile": "main",
      "sourceRoot": "apps/test-auth-scope/src",
      "compilerOptions": {
        "tsConfigPath": "apps/test-auth-scope/tsconfig.app.json"
      }
    },
    "ugc-service": {
      "type": "application",
      "root": "apps/ugc-service",
      "entryFile": "main",
      "sourceRoot": "apps/ugc-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/ugc-service/tsconfig.app.json"
      }
    },
    "user-service": {
      "type": "application",
      "root": "apps/user-service",
      "entryFile": "main",
      "sourceRoot": "apps/user-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/user-service/tsconfig.app.json",
        "assets": [
          {
            "include": "../static/**/*",
            "outDir": "dist/apps/user-service/static"
          }
        ]
      }
    },
    "wallet": {
      "type": "application",
      "root": "apps/wallet",
      "entryFile": "main",
      "sourceRoot": "apps/wallet/src",
      "compilerOptions": {
        "tsConfigPath": "apps/wallet/tsconfig.app.json",
        "assets": [
          "html/**/*"
        ]
      }
    },
    "wms": {
      "type": "application",
      "root": "apps/wms",
      "entryFile": "main",
      "sourceRoot": "apps/wms/src",
      "compilerOptions": {
        "tsConfigPath": "apps/wms/tsconfig.app.json"
      }
    }
  }
}
