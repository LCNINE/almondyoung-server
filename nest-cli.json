{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/almondyoung-server/src",
  "defaultLibraryPrefix": "@app",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/almondyoung-server/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/almondyoung-server",
  "projects": {
    "almondyoung-server": {
      "type": "application",
      "root": "apps/almondyoung-server",
      "entryFile": "main",
      "sourceRoot": "apps/almondyoung-server/src",
      "compilerOptions": {
        "tsConfigPath": "apps/almondyoung-server/tsconfig.app.json"
      }
    },
    "notification": {
      "type": "application",
      "root": "apps/notification",
      "entryFile": "main",
      "sourceRoot": "apps/notification/src",
      "compilerOptions": {
        "tsConfigPath": "apps/notification/tsconfig.app.json"
      }
    },
    "db": {
      "type": "library",
      "root": "libs/db",
      "entryFile": "index",
      "sourceRoot": "libs/db/src",
      "compilerOptions": {
        "tsConfigPath": "libs/db/tsconfig.lib.json"
      }
    },
    "pim": {
      "type": "application",
      "root": "apps/pim",
      "entryFile": "main",
      "sourceRoot": "apps/pim/src",
      "compilerOptions": {
        "tsConfigPath": "apps/pim/tsconfig.app.json"
      }
    },
    "roles": {
      "type": "library",
      "root": "libs/roles",
      "entryFile": "index",
      "sourceRoot": "libs/roles/src",
      "compilerOptions": {
        "tsConfigPath": "libs/roles/tsconfig.lib.json"
      }
    },
    "shared": {
      "type": "library",
      "root": "libs/shared",
      "entryFile": "index",
      "sourceRoot": "libs/shared/src",
      "compilerOptions": {
        "tsConfigPath": "libs/shared/tsconfig.lib.json"
      }
    },
    "user-service": {
      "type": "application",
      "root": "apps/user-service",
      "entryFile": "main",
      "sourceRoot": "apps/user-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/user-service/tsconfig.app.json"
      }
    },
    "wms": {
      "type": "application",
      "root": "apps/wms",
      "entryFile": "main",
      "sourceRoot": "apps/wms/src",
      "compilerOptions": {
        "tsConfigPath": "apps/wms/tsconfig.app.json"
      }
    },
    "wallet": {
      "type": "application",
      "root": "apps/wallet",
      "entryFile": "main",
      "sourceRoot": "apps/wallet/src",
      "compilerOptions": {
        "tsConfigPath": "apps/wallet/tsconfig.app.json",
        "assets": ["html/**/*"]
      }
    },
    "channel-adapter": {
      "type": "application",
      "root": "apps/channel-adapter",
      "entryFile": "main",
      "sourceRoot": "apps/channel-adapter/src",
      "compilerOptions": {
        "tsConfigPath": "apps/channel-adapter/tsconfig.app.json"
      }
    }
  }
}
