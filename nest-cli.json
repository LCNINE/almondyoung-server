{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/almondyoung-server/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/almondyoung-server/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/almondyoung-server",
  "projects": {
    "almondyoung-server": {
      "type": "application",
      "root": "apps/almondyoung-server",
      "entryFile": "main",
      "sourceRoot": "apps/almondyoung-server/src",
      "compilerOptions": {
        "tsConfigPath": "apps/almondyoung-server/tsconfig.app.json"
      }
    },
    "db": {
      "type": "library",
      "root": "libs/db",
      "entryFile": "index",
      "sourceRoot": "libs/db/src",
      "compilerOptions": {
        "tsConfigPath": "libs/db/tsconfig.lib.json"
      }
    },
    "wms": {
      "type": "application",
      "root": "apps/wms",
      "entryFile": "main",
      "sourceRoot": "apps/wms/src",
      "compilerOptions": {
        "tsConfigPath": "apps/wms/tsconfig.app.json"
      }
    }
  }
}