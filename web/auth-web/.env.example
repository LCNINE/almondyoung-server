# auth-web 환경변수 예시
# 로컬 개발: cp .env.example .env.local 후 값 수정

# user-service 서버 사이드 엔드포인트. 공개 URL도 되고 VPC 내부 URL도 된다.
USER_SERVICE_URL=https://user.df.dev.lcnine-dev2.com

# parent 도메인 쿠키 속성. user-service의 COOKIE_DOMAIN과 동일해야 한다.
PARENT_COOKIE_DOMAIN=.df.dev.lcnine-dev2.com
PARENT_COOKIE_SECURE=true
PARENT_COOKIE_SAMESITE=lax

# redirect_to 파라미터로 허용할 호스트. 쉼표로 구분. ".example.com" 접두사는 서브도메인 포함.
# OAuth 로그인 후 자기 자신(/oauth/authorize) 으로 복귀하기 위해 auth-web 호스트도 포함되어야 함.
ALLOWED_REDIRECT_HOSTS=.df.dev.lcnine-dev2.com,localhost:3000,localhost:8000

# auth-web 자체 origin (OAuth authorize 후 자기 자신으로 복귀할 때 사용)
AUTH_WEB_ORIGIN=https://auth.df.dev.lcnine-dev2.com

# OAuth IdP 연동
# user-service /oauth/internal/issue-code 호출용 shared secret. user-service의 OAUTH_INTERNAL_SECRET과 일치해야 함.
OAUTH_INTERNAL_SECRET=
# 허용할 OAuth client 화이트리스트. JSON 배열. clientId/redirectUris만 들어감 (secret은 user-service에만 있음).
# 예: [{"clientId":"daview","redirectUris":["https://daview.com/auth/callback"]}]
OAUTH_ALLOWED_CLIENTS=[]
