# Legacy (optional)
# NEXT_PUBLIC_BACKEND_URL='api게이트웨이주소'
# BACKEND_URL='api게이트웨이주소'

# 인증 일원화: auth-web (필수). 미인증 보호 경로 진입 시 이 origin 의 /signin 으로 redirect
AUTH_WEB_ORIGIN=https://auth.almondyoung-next.com

# user-service 직접 호출용 (server-side). restoreAccessToken/getMe 등에 사용
USER_SERVICE_URL=https://user.almondyoung-next.com

# OIDC RP 설정 — storefront 가 user-service /oauth/token 을 직접 호출 (refresh_token grant) 할 때 사용.
# Confidential client 이므로 client_secret 필수. 배포 환경(SST/Vercel) Secret 에도 반드시 등록.
OIDC_ISSUER_URL=https://user.almondyoung-next.com
OIDC_CLIENT_ID=medusa-storefront
OIDC_CLIENT_SECRET=

# 부모 도메인 쿠키 (auth-web 과 반드시 동일 값). 형제 서브도메인 간 세션 공유에 사용
PARENT_COOKIE_DOMAIN=.almondyoung-next.com
PARENT_COOKIE_SECURE=true
PARENT_COOKIE_SAMESITE=lax

# Firebase Web Push (FCM)
# Firebase 콘솔 > 프로젝트 설정 > 일반 > 내 앱 에서 확인
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Firebase 콘솔 > 프로젝트 설정 > 클라우드 메시징 > 웹 푸시 인증서 (VAPID 키)
NEXT_PUBLIC_FIREBASE_VAPID_KEY=
