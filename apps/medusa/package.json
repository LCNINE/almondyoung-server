{
  "name": "medusa-service",
  "version": "0.0.1",
  "description": "A starter for Medusa projects.",
  "author": "Medusa (https://medusajs.com)",
  "license": "MIT",
  "keywords": [
    "sqlite",
    "postgres",
    "typescript",
    "ecommerce",
    "headless",
    "medusa"
  ],
  "scripts": {
    "build": "medusa build",
    "predeploy": "medusa db:migrate --execute-safe-links",
    "seed": "medusa exec ./src/scripts/seed.ts",
    "seed:shipping": "medusa exec ./src/scripts/seed-shipping.ts",
    "backfill:run": "medusa exec ./src/scripts/backfill-from-core.ts",
    "repair:product-links": "medusa exec ./src/scripts/repair-product-links.ts",
    "disable-inventory": "medusa exec ./src/scripts/disable-inventory-management.ts",
    "fetch:sellmate": "medusa exec ./src/scripts/fetch-orders-sellmate.ts",
    "sellmate:fetch": "CACHE_REDIS_URL=${CACHE_REDIS_URL:-$REDIS_URL} XDG_CONFIG_HOME=${XDG_CONFIG_HOME:-/tmp} STATUS=${STATUS:-pending} yarn fetch:sellmate",
    "sellmate:filter": "node src/scripts/filter-sellmate-orders.js",
    "build:sellmate": "python3 src/scripts/build-sellmate-xls.py",
    "sellmate:export": "bash -lc 'set -euo pipefail; DATE_TAG=${DATE_TAG:-$(date +%Y%m%d)}; MIN_ID=${MIN_DISPLAY_ID:-1}; FETCH_OUT=${FETCH_OUTPUT:-sellmate-orders-${DATE_TAG}-pending.json}; FILTER_OUT=${FILTER_OUTPUT:-sellmate-orders-from-${MIN_ID}-${DATE_TAG}.json}; XLS_OUT=${XLS_OUTPUT:-orders-sellmate-from-${MIN_ID}-${DATE_TAG}.xls}; OUTPUT=\"$FETCH_OUT\" yarn sellmate:fetch; INPUT=\"$FETCH_OUT\" OUTPUT=\"$FILTER_OUT\" MIN_DISPLAY_ID=\"$MIN_ID\" yarn sellmate:filter; INPUT=\"$FILTER_OUT\" OUTPUT=\"$XLS_OUT\" PYTHONPATH=${PYTHONPATH:-.pydeps} yarn build:sellmate'",
    "start": "medusa exec ./src/scripts/seed.ts && medusa exec ./src/scripts/seed-shipping.ts && medusa start",
    "dev": "medusa develop",
    "test:integration:http": "TEST_TYPE=integration:http NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:integration:modules": "TEST_TYPE=integration:modules NODE_OPTIONS=--experimental-vm-modules jest --silent --runInBand --forceExit",
    "test:unit": "TEST_TYPE=unit NODE_OPTIONS=--experimental-vm-modules jest --silent --runInBand --forceExit"
  },
  "dependencies": {
    "@medusajs/admin-sdk": "2.13.4",
    "@medusajs/api-key": "2.13.4",
    "@medusajs/cli": "2.13.4",
    "@medusajs/draft-order": "2.13.4",
    "@medusajs/framework": "2.13.4",
    "@medusajs/medusa": "2.13.4",
    "@medusajs/ui": "4.1.4",
    "@medusajs/ui-preset": "^2.11.3",
    "@mikro-orm/core": "6.4.16",
    "@mikro-orm/knex": "6.4.16",
    "@mikro-orm/migrations": "6.4.16",
    "@mikro-orm/postgresql": "6.4.16",
    "@radix-ui/react-visually-hidden": "^1.1.1",
    "awilix": "^8.0.1",
    "axios": "^1.10.0",
    "jose": "^5.9.6",
    "pg": "^8.13.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@medusajs/test-utils": "2.13.4",
    "@mikro-orm/cli": "6.4.16",
    "@swc/core": "^1.7.28",
    "@swc/jest": "^0.2.36",
    "@types/bcrypt": "^5.0.2",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.2.25",
    "jest": "^29.7.0",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "vite": "^5.2.11",
    "xlsx": "^0.18.5",
    "yalc": "^1.0.0-pre.53"
  },
  "engines": {
    "node": ">=20"
  }
}
