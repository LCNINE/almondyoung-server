# ========================================
# Core(구 PIM) → Medusa Backfill Migration 환경 변수
# ========================================
#
# 사용법:
#   1. 이 파일을 .env.migration으로 복사
#   2. 실제 값으로 변경
#   3. npm run migrate:prefill-categories
#   4. npm run migrate:backfill
#

# ===== 필수 환경 변수 =====

# Core(구 PIM) 데이터베이스 (읽기 전용)
# - PIM이 almondyoung-server(Core)로 통합된 이후 동일 DB를 가리킴
# - SST 터널 경유 권장 (스크립트 풀 max=1로 보수 설정)
CORE_DB_URL=postgresql://user:password@localhost:5432/core_db

# Channel Adapter 데이터베이스 (매핑 테이블, 진행률/실패 저장)
DATABASE_URL=postgresql://user:password@localhost:5432/channel_adapter_db

# Medusa API 엔드포인트
MEDUSA_API_URL=http://localhost:9000

# Medusa Admin API Key (sk_* 형식)
MEDUSA_API_KEY=sk_your_api_key_here


# ===== 선택적 환경 변수 =====

# 파일 서비스 URL (이미지 URL 생성용)
# 없으면 Core의 fileId를 그대로 사용
FILE_SERVICE_URL=http://localhost:3000

# Medusa 멤버십 고객 그룹 ID (Price List 동기화용)
# 없으면 멤버십 가격 동기화 스킵
MEDUSA_MEMBERSHIP_GROUP_ID=cgrp_membership_group_id

# 가격 없는 variants 스킵 여부 (true/false)
# true: basePrice가 없는 variants는 동기화하지 않음
SKIP_VARIANTS_WITHOUT_PRICE=false

# 동기화 시 바코드 제거 (테스트용, true/false)
# true: barcode 필드를 undefined로 설정
STRIP_BARCODE_ON_SYNC=false

# Attach 단계에서 제외할 카테고리 — '전체상품 보기' 같은 mass-attach 카테고리가 있다면
# row lock 직렬화로 concurrency 가 죽지 않도록 명시 제외 (콤마 구분)
# SKIP_ATTACH_CATEGORY_IDS=
# SKIP_ATTACH_CATEGORY_SLUGS=all-products,everything
