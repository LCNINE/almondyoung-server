# ==========================================
# File Service Environment Variables
# ==========================================

# ------------------------------------------
# Database Configuration
# ------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/almondyoung_dev
PORT=3005

# ------------------------------------------
# Authentication
# ------------------------------------------
AUTH_SECRET=your-secret-key-min-32-characters-long

# ------------------------------------------
# Kafka Configuration (Event Streaming)
# ------------------------------------------
KAFKA_CLIENT_ID_PREFIX=file-service
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=file-service-group

# Optional: Confluent Cloud / SASL Authentication
# KAFKA_API_KEY=your-kafka-api-key
# KAFKA_API_SECRET=your-kafka-api-secret

# ------------------------------------------
# Storage Provider Configuration
# ------------------------------------------
# Options: S3 | LOCAL
# - Use LOCAL for development
# - Use S3 for production
STORAGE_PROVIDER=LOCAL

# ------------------------------------------
# AWS S3 Configuration (Required when STORAGE_PROVIDER=S3)
# ------------------------------------------
# AWS Region (e.g., ap-northeast-2 for Seoul)
AWS_REGION=ap-northeast-2

# AWS Credentials
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# S3 Buckets
# - Public bucket: for publicly accessible files (e.g., product images)
# - Private bucket: for private files requiring signed URLs
AWS_S3_PUBLIC_BUCKET=your-public-bucket-name
AWS_S3_PRIVATE_BUCKET=your-private-bucket-name

# ------------------------------------------
# Notes
# ------------------------------------------
# 1. For local development:
#    - Set STORAGE_PROVIDER=LOCAL
#    - AWS variables can be left empty
#
# 2. For production:
#    - Set STORAGE_PROVIDER=S3
#    - All AWS_* variables are REQUIRED
#
# 3. Database URL format:
#    postgresql://[user]:[password]@[host]:[port]/[database]
#
# 4. Security:
#    - Never commit .env files to version control
#    - Use strong AUTH_SECRET (min 32 characters)
#    - Rotate AWS credentials regularly
