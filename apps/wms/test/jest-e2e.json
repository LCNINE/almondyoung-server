{
  "moduleFileExtensions": [
    "js",
    "json",
    "ts"
  ],
  "rootDir": ".",
  "testEnvironment": "node",
  "setupFiles": [
    "<rootDir>/env-setup.ts"
  ],
  "testRegex": ".*\\.e2e(\\.|-)spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@app/db(|/.*)$": "<rootDir>/../../../libs/db/src/$1"
  },
  "verbose": true,
  "testLocationInResults": true
}
