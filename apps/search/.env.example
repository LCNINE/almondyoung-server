# ──────────────────────────────────────────
# OpenSearch / Elasticsearch
# ──────────────────────────────────────────
OPENSEARCH_NODE=https://your-opensearch.up.railway.app
OPENSEARCH_USERNAME=elastic
OPENSEARCH_PASSWORD=your-password
# 인덱스 이름 (기본값: search_products)
SEARCH_PRODUCTS_INDEX=search_products

# ──────────────────────────────────────────
# Kafka (Confluent Cloud)
# ──────────────────────────────────────────
KAFKA_CLIENT_ID_PREFIX=search
KAFKA_BROKERS=pkc-xxxxx.ap-northeast-2.aws.confluent.cloud:9092
KAFKA_API_KEY=your-kafka-api-key
KAFKA_API_SECRET=your-kafka-api-secret
# Consumer group (기본값: search-indexer)
KAFKA_GROUP_ID=search-indexer

# ──────────────────────────────────────────
# Server
# ──────────────────────────────────────────
PORT=3004

# ──────────────────────────────────────────
# Backfill 스크립트 전용 (search:backfill 실행 시 필요)
# ──────────────────────────────────────────
PIM_SOURCE_DB_URL=postgresql://user:password@host/pim
# 썸네일 URL 생성용 (선택)
FILE_SERVICE_URL=http://localhost:3002
