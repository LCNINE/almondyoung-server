# ─── Required ────────────────────────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/wallet

# API key for authenticating requests from server-to-server callers (e.g. wallet-web Route Handlers)
# Must match WALLET_API_KEY in apps/wallet-web/.env.local
WALLET_API_KEY=dev-secret

# ─── Server ───────────────────────────────────────────────────────────────────

PORT=3100
NODE_ENV=development
SERVICE_NAME=wallet

# Comma-separated allowed CORS origins (production only; ignored when NODE_ENV != production)
# WALLET_CORS_ORIGINS=https://app.example.com,https://admin.example.com

# ─── Idempotency ─────────────────────────────────────────────────────────────

# TTL for idempotency keys in seconds (default: 86400 = 24h)
# WALLET_IDEMPOTENCY_TTL_SECONDS=86400

# ─── Intent expiration job ───────────────────────────────────────────────────

# Cron schedule for expiring stale payment intents (default: every minute)
# WALLET_EXPIRATION_CRON=* * * * *
# WALLET_EXPIRATION_BATCH_SIZE=100

# ─── Toss Payments ───────────────────────────────────────────────────────────

# Server-side secret key (test_sk_... for test, live_sk_... for production)
# TOSS_SECRET_KEY=test_sk_...

# Client-side public key (test_ck_... for test, live_ck_... for production)
# TOSS_CLIENT_KEY=test_ck_...

# ─── Bank Transfer (무통장입금) ────────────────────────────────────────────────

# Company bank account information displayed to customers after confirm
# BANK_TRANSFER_BANK_NAME=신한은행
# BANK_TRANSFER_ACCOUNT_NUMBER=110-123-456789
# BANK_TRANSFER_ACCOUNT_HOLDER=주식회사 아몬드영

# ─── Outbox dispatcher job ───────────────────────────────────────────────────

# Cron schedule for dispatching outbox events (default: every 10 seconds)
# WALLET_OUTBOX_DISPATCH_CRON=*/10 * * * * *
# WALLET_OUTBOX_BATCH_SIZE=50
# WALLET_OUTBOX_MAX_ATTEMPTS=5
# WALLET_OUTBOX_BASE_DELAY_MS=1000
# WALLET_OUTBOX_MAX_DELAY_MS=60000
# WALLET_OUTBOX_PROCESSING_TIMEOUT_SECONDS=30
# WALLET_OUTBOX_DEAD_LETTER_ENABLED=true
