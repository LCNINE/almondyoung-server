{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "../",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@app/db$": "<rootDir>/../libs/db/src",
    "^@app/db/(.*)$": "<rootDir>/../libs/db/src/$1",
    "^@app/events$": "<rootDir>/../libs/events/src",
    "^@app/events/(.*)$": "<rootDir>/../libs/events/src/$1"
  },
  "globalSetup": "<rootDir>/wallet/test/global-setup.ts"
}
