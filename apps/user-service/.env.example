# === Application Settings ===
NODE_ENV=development
PORT=3030

# === CORS ===
# 프론트엔드 오리진 주소 (예: 로컬 개발 시)
CORS_ORIGIN_DOMAIN=http://localhost:8000

# === Database & Cache ===
DATABASE_URL=postgresql://<username>:<password>@<host>/<database>?sslmode=require
REDIS_URL=redis://localhost:6379

# === Kafka (Confluent Cloud) ===
KAFKA_BROKERS=pkc-xxxxx.ap-northeast-2.aws.confluent.cloud:9092
KAFKA_API_KEY=your-kafka-api-key
KAFKA_API_SECRET=your-kafka-api-secret
KAFKA_CLIENT_ID_PREFIX=user-service
KAFKA_GROUP_ID=user-consumer

# === JWT & Security ===
AUTH_SECRET=your-auth-secret
JWT_REFRESH_SECRET=your-refresh-secret
JWT_VERIFICATION_TOKEN_SECRET=your-verification-token-secret

# === OAuth IdP (RS256 access token signing) ===
# Generate a 2048-bit RSA keypair (PKCS#8 / SPKI):
#   openssl genpkey -algorithm RSA -pkcs8 -out priv.pem -pkeyopt rsa_keygen_bits:2048
#   openssl pkey -in priv.pem -pubout -out pub.pem
# In .env files, escape newlines as literal \n. SST/Secrets Manager accept multiline natively.
OAUTH_JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
OAUTH_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----\n"
OAUTH_JWT_KID=oauth-local-1
OAUTH_ISSUER_URL=http://localhost:3030
# auth-web origin — OIDC discovery 의 authorization_endpoint 로 광고됨.
AUTH_WEB_ORIGIN=http://localhost:8000

# === Pre-registered OAuth clients ===
# JSON array. `clientSecretHash` 는 bcrypt 해시(원문 secret 은 운영자가 별도 보관).
# 시드: `npm run seed:oauth-clients` (apps/user-service/.env 의 OAUTH_CLIENTS 를 읽어 oauth_clients 테이블에 1회 삽입; 멱등)
# medusa-storefront 항목은 medusa의 confidential OIDC 클라이언트로 사용됨.
# bcrypt 해시 생성 예: node -e "console.log(require('bcrypt').hashSync('REPLACE_WITH_PLAINTEXT', 12))"
OAUTH_CLIENTS='[{"clientId":"medusa-storefront","clientSecretHash":"$2b$12$REPLACE_WITH_BCRYPT_HASH","redirectUris":["http://localhost:8000/kr/callback/oidc"],"allowedScopes":["openid","email","profile"]}]'

# === OAuth (Social Login) ===
KAKAO_CLIENT_ID=your-kakao-client-id
KAKAO_CLIENT_SECRET=your-kakao-client-secret
KAKAO_CALLBACK_URL=http://localhost:3030/auth/kakao/callback

# === AWS S3 (File Storage) ===
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=your-s3-bucket-name

# === Payment & External APIs ===
# HMS BNPL
HMS_API_KEY=your-hms-api-key
HMS_API_SECRET=your-hms-api-secret

# === Twilio (SMS) ===
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# === Firebase (Push Notifications) ===
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase-client-email

# === Naver Commerce API ===
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret

# === Coupang API ===
COUPANG_ACCESS_KEY=your-coupang-access-key
COUPANG_SECRET_KEY=your-coupang-secret-key

# === Cafe24 OAuth ===
CAFE24_CLIENT_ID=your-cafe24-client-id
CAFE24_CLIENT_SECRET=your-cafe24-client-secret
# Optional override. If not set, https://{mall_id}.cafe24api.com/api/v2/oauth/token is used.
CAFE24_TOKEN_URL=https://your-mall-id.cafe24api.com/api/v2/oauth/token

# === Cafe24 Link ===
CAFE24_SERVICE_KEY=your-cafe24-service-key
# Cafe24 mall id is fixed to lcnine in user-service
CAFE24_API_VERSION=2025-12-01

# === Logging & Debug ===
LOG_LEVEL=info
DEBUG=false

# === Internal Service URLs ===
WMS_SERVICE_URL=http://localhost:3010
PIM_SERVICE_URL=http://localhost:3020
USER_SERVICE_URL=http://localhost:3030
WALLET_SERVICE_URL=http://localhost:3040
MEMBERSHIP_SERVICE_URL=http://localhost:3050
NOTIFICATION_SERVICE_URL=http://localhost:3060
CHANNEL_ADAPTER_SERVICE_URL=http://localhost:3070
