# 루트 디렉토리에 설정 .env 설정 

# 데이터베이스 설정
DATABASE_URL=postgresql://username:password@your-database-host/database-name?sslmode=require

# 서버 설정
PORT=5000
APP_URL="http://localhost:5000"

# CORS 설정
CORS_ORIGIN_DOMAIN=http://localhost:8000

# 프론트엔드 URL 설정
EMAIL_RESET_PASSWORD_URL="http://localhost:8000/reset-password"
SIGNUP_REDIRECT_URL="http://localhost:8000/auth/callback/signup"

# JWT 인증 설정
AUTH_SECRET="your-auth-secret-key"
JWT_VERIFICATION_TOKEN_SECRET='your-jwt-verification-secret'
JWT_REFRESH='your-jwt-refresh-secret'
JWT_ACCESS_TOKEN_EXPIRATION='30d'
JWT_RESET_PASSWORD_ACCESS_TOKEN_EXPIRATION='5m'
JWT_REFRESH_TOKEN_EXPIRATION=2w          # 일반 로그인 (2주)
JWT_REFRESH_TOKEN_LONG_EXPIRATION=90d     # 자동 로그인 (90일)
JWT_EMAIL_VERIFICATION_ACCESS_TOKEN_EXPIRATION='10m'

# 이메일 서비스 설정 (Resend)
RESEND_API_KEY='your-resend-api-key'

# 카카오 OAuth 설정
KAKAO_CLIENT_ID=your-kakao-client-id
KAKAO_CLIENT_SECRET=your-kakao-client-secret
KAKAO_CALLBACK_URL=http://localhost:5000/auth/kakao/callback

# Medusa 설정
MEDUSA_CALLBACK_URL=http://localhost:9000/auth/user/my-auth

# KAFKA 설정
KAFKA_CLIENT_ID=user-service
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=user-consumer


#AWS
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=