# ===========================================
# AlmondYoung Server Environment Variables (Example)
# ===========================================

# === Application Settings ===
# Environment mode: development | production
NODE_ENV=development

# Server listening port (Railway sets PORT automatically)
PORT=3030

# CORS origins (comma-separated)
CORS_ORIGIN_DOMAIN_PROD=https://your-production-domain.com
CORS_ORIGIN_DOMAIN_DEV=http://localhost:8000


# === Database (Neon PostgreSQL) ===
# Format: postgresql://[user]:[password]@[host]/[dbname]?sslmode=require
DATABASE_URL=postgresql://<USER>:<PASSWORD>@<HOST>/<DBNAME>?sslmode=require
PIM_DATABASE_URL=postgresql://<USER>:<PASSWORD>@<HOST>/<DBNAME>?sslmode=require


# === Redis (Optional) ===
# Example for local Redis or managed provider
REDIS_URL=redis://localhost:6379


# === Kafka (Confluent Cloud or Local) ===
KAFKA_BROKERS=<BROKER_URL>:9092
KAFKA_API_KEY=<YOUR_KAFKA_API_KEY>
KAFKA_API_SECRET=<YOUR_KAFKA_API_SECRET>
KAFKA_CLIENT_ID_PREFIX=user-service
KAFKA_GROUP_ID=user-consumer


# === JWT & Security ===
AUTH_SECRET=<YOUR_AUTH_SECRET>
JWT_REFRESH_SECRET=<YOUR_JWT_REFRESH_SECRET>
JWT_VERIFICATION_TOKEN_SECRET=<YOUR_JWT_VERIFICATION_SECRET>


# === Kakao OAuth2 ===
KAKAO_CLIENT_ID=<YOUR_KAKAO_CLIENT_ID>
KAKAO_CLIENT_SECRET=<YOUR_KAKAO_CLIENT_SECRET>
KAKAO_CALLBACK_URL=https://your-domain.com/auth/kakao/callback


# === AWS S3 (File Storage) ===
AWS_ACCESS_KEY_ID=<YOUR_AWS_ACCESS_KEY_ID>
AWS_SECRET_ACCESS_KEY=<YOUR_AWS_SECRET_ACCESS_KEY>
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=almondyoung


# === Payment & External APIs ===
# HMS (BNPL)
HMS_API_KEY=<YOUR_HMS_API_KEY>
HMS_API_SECRET=<YOUR_HMS_SECRET>

# Twilio (SMS)
TWILIO_ACCOUNT_SID=<YOUR_TWILIO_SID>
TWILIO_AUTH_TOKEN=<YOUR_TWILIO_AUTH_TOKEN>

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=<YOUR_FIREBASE_PROJECT_ID>
FIREBASE_PRIVATE_KEY=<YOUR_FIREBASE_PRIVATE_KEY>
FIREBASE_CLIENT_EMAIL=<YOUR_FIREBASE_CLIENT_EMAIL>


# === Naver Commerce API ===
NAVER_CLIENT_ID=<YOUR_NAVER_CLIENT_ID>
NAVER_CLIENT_SECRET=<YOUR_NAVER_CLIENT_SECRET>

# === Coupang API ===
COUPANG_ACCESS_KEY=<YOUR_COUPANG_ACCESS_KEY>
COUPANG_SECRET_KEY=<YOUR_COUPANG_SECRET_KEY>


# === Logging / Debug ===
LOG_LEVEL=info
DEBUG=false


# === Internal Service URLs ===
# (Use environment-based URLs in production)
WMS_SERVICE_URL=http://localhost:3010
PIM_SERVICE_URL=http://localhost:3020
USER_SERVICE_URL=http://localhost:3030
WALLET_SERVICE_URL=http://localhost:3040
MEMBERSHIP_SERVICE_URL=http://localhost:3050
NOTIFICATION_SERVICE_URL=http://localhost:3060
CHANNEL_ADAPTER_SERVICE_URL=http://localhost:3070
