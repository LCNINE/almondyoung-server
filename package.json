  "jest": {
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "moduleNameMapper": {
      "^@app/auth-core(|/.*)$": "<rootDir>/libs/auth-core/src/$1",
      "^@app/authorization(|/.*)$": "<rootDir>/libs/authorization/src/$1",
      "^@app/db(|/.*)$": "<rootDir>/libs/db/src/$1",
      "^@app/events(|/.*)$": "<rootDir>/libs/events/src/$1",
      "^@app/shared(|/.*)$": "<rootDir>/libs/shared/src/$1",
      "^@packages/event-contracts/(.*)$": "<rootDir>/packages/event-contracts/$1",
      "^@packages/domain-types(|/.*)$": "<rootDir>/packages/domain-types$1"
    },
    "modulePathIgnorePatterns": [
      "<rootDir>/apps/medusa/.medusa"
    ],
    "rootDir": ".",
    "roots": [
      "<rootDir>/apps/",
      "<rootDir>/libs/"
    ],
    "testEnvironment": "node",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    }
  },
