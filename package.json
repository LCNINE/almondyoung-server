    "test:api": "newman run postman/File-Service-MIME-Validation.postman_collection.json -e postman/File-Service-Local.postman_environment.json",
    "test:api:ci": "npm run test:api:setup && npm run test:api -- --bail",
    "test:api:report": "npm run test:api -- --reporters cli,htmlextra --reporter-htmlextra-export test-results/api-test-report.html",
