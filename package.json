{
  "name": "almondyoung-server",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build && nest build wallet && nest build wms",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/apps/almondyoung-server/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./apps/almondyoung-server/test/jest-e2e.json",
    "test:payment": "jest --testPathPattern=payment.*spec.ts",
    "test:payment:watch": "jest --testPathPattern=payment.*spec.ts --watch",
    "test:payment:hms": "jest --testPathPattern=payment.*spec.ts --testNamePattern=\"HMS\"",
    "test:payment:real": "jest --testPathPattern=payment.*spec.ts --testNamePattern=\"실제 API\"",
    "test:payment:integration": "jest --testPathPattern=payment-flow.integration.spec.ts",
    "test:naver-token": "ts-node apps/channel-adapter/test-naver-token.ts",
    "test:naver-sync": "ts-node apps/channel-adapter/test-naver-sync.ts",
    "test:naver-sync:token": "ts-node apps/channel-adapter/test-naver-sync.ts token",
    "test:orchestration": "ts-node apps/channel-adapter/test-orchestration.ts",
    "test:orchestration:poll": "ts-node apps/channel-adapter/test-orchestration.ts poll",
    "test:bnpl:itdoc": "jest --testPathPattern=bnpl-api.itdoc.spec.ts --verbose",
    "test:orchestration:webhook": "ts-node apps/channel-adapter/test-orchestration.ts webhook",
    "test:orchestration:command": "ts-node apps/channel-adapter/test-orchestration.ts command",
    "test:coupang:sync": "ts-node apps/channel-adapter/test-coupang-sync.ts",
    "mock:naver-server": "ts-node apps/channel-adapter/naver-mock-server.ts",
    "mock:naver-server:bg": "ts-node apps/channel-adapter/naver-mock-server.ts &"
  },
  "dependencies": {
    "@fastify/multipart": "^9.0.3",
    "@fastify/static": "^8.2.0",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/microservices": "^11.1.3",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-fastify": "^11.1.6",
    "@nestjs/schedule": "^6.0.0",
    "@nestjs/swagger": "^11.2.0",
    "@types/bcrypt": "^6.0.0",
    "axios": "^1.11.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cors": "^2.8.5",
    "drizzle-kit": "^0.31.4",
    "drizzle-orm": "^0.44.5",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "form-data": "^4.0.4",
    "hms-api-wrapper": "file:../hms-api-wrapper/hms-api-wrapper-1.0.0.tgz",
    "kafkajs": "^2.2.4",
    "nestjs-zod": "^5.0.1",
    "node-fetch": "^2.7.0",
    "pg": "^8.16.2",
    "postgres": "^3.4.7",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "tsid-ts": "^0.0.9",
    "ulid": "^3.0.1",
    "uuid": "^11.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@faker-js/faker": "^10.0.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.7",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.7",
    "@types/pg": "^8.15.4",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/parser": "^8.42.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "itdoc": "^0.4.1",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.1.4",
    "test-data-bot": "^0.8.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": [
        "ts-jest",
        {
          "tsconfig": {
            "paths": {
              "@app/db": [
                "libs/db/src"
              ],
              "@app/db/*": [
                "libs/db/src/*"
              ],
              "@app/events": [
                "libs/events/src"
              ],
              "@app/events/*": [
                "libs/events/src/*"
              ],
              "@app/shared": [
                "libs/shared/src"
              ],
              "@app/shared/*": [
                "libs/shared/src/*"
              ]
            }
          }
        }
      ]
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "globalSetup": "<rootDir>/apps/wallet/test/global-setup.ts",
    "roots": [
      "<rootDir>/apps/",
      "<rootDir>/libs/"
    ],
    "moduleNameMapper": {
      "^@app/db$": "<rootDir>/libs/db/src",
      "^@app/db/(.*)$": "<rootDir>/libs/db/src/$1",
      "^@app/events$": "<rootDir>/libs/events/src",
      "^@app/events/(.*)$": "<rootDir>/libs/events/src/$1",
      "^@app/shared$": "<rootDir>/libs/shared/src",
      "^@app/shared/(.*)$": "<rootDir>/libs/shared/src/$1"
    }
  },
  "itdoc": {
    "output": "./docs/api",
    "document": {
      "baseUrl": "https://api.almondyoung.com",
      "title": "AlmondYoung BNPL API Documentation",
      "description": "BNPL(나중결제) 시스템의 API 문서입니다. 결제 프로필 생성, 결제 처리, 환불 등의 기능을 제공합니다."
    }
  }
}
