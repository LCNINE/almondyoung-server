  "scripts": {
    "build": "npm run build:all",
    "build:admin-web": "cd apps/admin-web && npm run build",
    "build:all": "nest build core && nest build user-service && nest build wallet && nest build membership && nest build notification && nest build channel-adapter && nest build outbox-demo && nest build orchestrator && nest build file-service && nest build search",
    "build:analytics": "nest build analytics",
    "build:channel-adapter": "nest build channel-adapter",
    "build:core": "nest build core",
    "build:file-service": "nest build file-service",
    "build:main": "nest build core",
    "build:membership": "nest build membership",
    "build:notification": "nest build notification",
    "build:orchestrator": "nest build orchestrator",
    "build:outbox-demo": "nest build outbox-demo",
    "build:search": "nest build search",
    "build:ugc-service": "nest build ugc-service",
    "build:user-service": "nest build user-service",
    "build:wallet": "nest build wallet",
    "db:setup": "npx tsx scripts/seeding/index.ts",
    "db:setup:lcnine-auth": "npx tsx scripts/seeding/index.ts --deployment lcnine-auth",
    "db:setup:ci": "npx tsx scripts/seeding/index.ts --yes",
    "db:generate:analytics": "drizzle-kit generate --config apps/analytics/drizzle.config.ts",
    "db:generate:channel-adapter": "drizzle-kit generate --config apps/channel-adapter/drizzle.config.ts",
    "db:generate:core": "drizzle-kit generate --config apps/core/drizzle.config.ts",
    "db:generate:file-service": "drizzle-kit generate --config apps/file-service/drizzle.config.ts",
    "db:generate:membership": "drizzle-kit generate --config apps/membership/drizzle.config.ts",
    "db:generate:notification": "drizzle-kit generate --config apps/notification/database/drizzle/drizzle.config.ts",
    "db:generate:outbox-demo": "cd apps/outbox-demo && drizzle-kit generate",
    "db:generate:ugc-service": "drizzle-kit generate --config apps/ugc-service/src/db/drizzle.config.ts",
    "db:generate:user-service": "drizzle-kit generate --config apps/user-service/database/drizzle/drizzle.config.ts",
    "db:generate:wallet": "drizzle-kit generate --config apps/wallet/drizzle.config.ts",
    "db:pull:ugc-service": "./scripts/with-ipv4.sh drizzle-kit pull --config apps/ugc-service/src/db/drizzle.config.ts",
    "tunnel:auth": "./scripts/sst-tunnel.sh deployments/lcnine/auth",
    "tunnel:services": "./scripts/sst-tunnel.sh deployments/lcnine/services",
    "db:setup:auth": "cd deployments/lcnine/auth && npx tsx ../../../scripts/seeding/index.ts --deployment lcnine-auth",
    "db:setup:services": "cd deployments/lcnine/services && npx tsx ../../../scripts/seeding/index.ts --deployment lcnine-services",
    "db:seed": "npm run db:seed:membership",
    "db:seed:billing-test": "npm run db:seed:membership:billing-test",
    "db:seed:membership": "cd apps/membership && npx tsx drizzle/seed.ts",
    "db:seed:membership:billing-test": "cd apps/membership && npx tsx drizzle/seed.ts",
    "db:seed:user-service": "ts-node -r tsconfig-paths/register apps/user-service/database/seed-cli.ts",
    "docs:generate": "ts-node --transpile-only scripts/generate-swagger-docs.ts",
    "docs:membership": "npm run docs:generate membership",
    "docs:notification": "ts-node -r tsconfig-paths/register apps/notification/generate-swagger-docs.ts",
    "docs:serve": "npx itdoc serve",
    "docs:user-service": "ts-node --transpileOnly -r tsconfig-paths/register apps/user-service/generate-swagger-docs.ts",
    "docs:wallet": "npm run docs:generate wallet",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "gen:scope-types": "ts-node -r tsconfig-paths/register apps/user-service/database/generate-scope-types.ts",
    "generate:token": "node scripts/generate-jwt-token.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:admin-web": "cd apps/admin-web && npm run lint",
