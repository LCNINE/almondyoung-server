{
  "name": "almondyoung-server",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/apps/almondyoung-server/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./apps/almondyoung-server/test/jest-e2e.json",
    "wms:test": "jest --config apps/wms/jest.config.js",
    "wms:test:watch": "jest --config apps/wms/jest.config.js --watch",
    "wms:test:debug": "jest --config apps/wms/jest.config.js --verbose",
    "db:push.wms": "drizzle-kit push --config apps/wms/database/drizzle/drizzle.config.ts",
    "db:push.wms:test": "drizzle-kit push --config apps/wms/database/drizzle/drizzle.test-config.ts",
    "db:generate.wms": "drizzle-kit generate --config apps/wms/database/drizzle/drizzle.config.ts",
    "build:wms": "nest build wms",
    "start:wms": "nest start wms",
    "start:wms:dev": "nest start wms --watch",
    "start:wms:prod": "node dist/apps/wms/main.js",
    "db:generate:pim": "cd apps/pim && drizzle-kit generate",
    "db:migrate:pim": "cd apps/pim && drizzle-kit migrate",
    "db:push:pim": "cd apps/pim && drizzle-kit push",
    "docs:generate": "ts-node --transpile-only scripts/generate-swagger-docs.ts",
    "docs:wms": "npm run docs:generate wms",
    "docs:pim": "npm run docs:generate pim"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/mapped-types": "*",
    "@nestjs/microservices": "^11.1.3",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "github:nestjs/swagger",
    "axios": "^1.11.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^17.2.0",
    "drizzle-orm": "^0.44.2",
    "kafkajs": "^2.2.4",
    "nestjs-zod": "^4.3.1",
    "pg": "^8.16.2",
    "postgres": "^3.4.7",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.1.0",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@faker-js/faker": "^10.0.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.7",
    "@testcontainers/postgresql": "^11.6.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.34",
    "@types/pg": "^8.15.4",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "testcontainers": "^11.6.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/",
      "<rootDir>/libs/"
    ],
    "moduleNameMapper": {
      "^@app/db(|/.*)$": "<rootDir>/libs/db/src/$1",
      "^@app/events(|/.*)$": "<rootDir>/libs/events/src/$1",
      "^@app/shared(|/.*)$": "<rootDir>/libs/shared/src/$1"
    }
  }
}
