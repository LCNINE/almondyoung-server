							"mode": "formdata",
							"formdata": [
								{
									"key": "file",
									"type": "file",
									"src": "test-files/malicious.html",
									"description": "HTML file sent as image/png"
								},
								{
									"key": "contextId",
									"value": "product-image",
									"type": "text"
								}
							]
						},
						"url": {
							"raw": "{{baseUrl}}/upload",
							"host": ["{{baseUrl}}"],
							"path": ["files", "upload"]
						}
					}
				},
				{
					"name": "1.3 Accept JPEG with wrong Content-Type (warn)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Should accept file (detected type is valid)', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response contains file metadata', function () {",
									"    const response = pm.response.json();",
									"    pm.expect(response).to.have.property('id');",
									"    pm.expect(response).to.have.property('url');",
									"    pm.expect(response.status).to.equal('active');",
									"});",
									"",
									"// Save file ID for cleanup",
									"if (pm.response.code === 200) {",
									"    const response = pm.response.json();",
									"    pm.collectionVariables.set('lastUploadedFileId', response.id);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{authToken}}"
							}
						],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "file",
									"type": "file",
									"src": "test-files/valid-image.jpg",
									"description": "Real JPEG but sent as application/octet-stream"
								},
								{
									"key": "contextId",
									"value": "product-image",
									"type": "text"
								}
							]
						},
						"url": {
							"raw": "{{baseUrl}}/upload",
							"host": ["{{baseUrl}}"],
							"path": ["files", "upload"]
						}
					}
				}
			]
		},
