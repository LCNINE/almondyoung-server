{
	"info": {
		"name": "File Service - MIME Type Validation Tests",
		"description": "Test suite for file upload MIME type validation with magic number detection",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Setup",
			"item": [
				{
					"name": "Health Check",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Server is running', function () {",
									"    pm.response.to.have.status(200);",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}",
							"host": ["{{baseUrl}}"],
							"path": []
						}
					}
				}
			]
		},
		{
			"name": "1. Security Tests",
			"item": [
				{
					"name": "1.1 Reject EXE disguised as JPG",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Should reject executable file', function () {",
									"    pm.response.to.have.status(400);",
									"});",
									"",
									"pm.test('Error message mentions file type', function () {",
									"    const response = pm.response.json();",
									"    pm.expect(response.message).to.include('Invalid file type');",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{authToken}}"
							}
						],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "file",
									"type": "file",
									"src": "test-files/malicious.exe.jpg",
									"description": "Executable file with .jpg extension"
								},
								{
									"key": "contextId",
									"value": "product-image",
									"type": "text"
								}
							]
						},
						"url": {
							"raw": "{{baseUrl}}/upload",
							"host": ["{{baseUrl}}"],
							"path": ["files", "upload"]
						}
					}
				},
				{
					"name": "1.2 Reject HTML with image Content-Type",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Should reject HTML file', function () {",
									"    pm.response.to.have.status(400);",
									"});",
									"",
									"pm.test('Error message mentions file type', function () {",
									"    const response = pm.response.json();",
									"    pm.expect(response.message).to.include('Invalid file type');",
